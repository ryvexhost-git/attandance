{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/web",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "server/prisma/schema.prisma"
    }
  }
}
