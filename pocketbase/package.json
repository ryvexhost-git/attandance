{
	"name": "pocketbase-app",
	"type": "module",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": ".\\pocketbase serve --http=0.0.0.0:8090 --hooksWatch=false",
		"start": ".\\pocketbase serve --http=0.0.0.0:8090 --dir=/data --migrationsDir=./pb_migrations --hooksDir=./pb_hooks --hooksWatch=false",
		"migrations:up": ".\\pocketbase horizons migrations:up --dir=./pb_data --migrationsDir=./pb_migrations --hooksDir=./pb_hooks --hooksWatch=false",
		"migrations:revert": ".\\pocketbase horizons migrations:revert --dir=./pb_data --migrationsDir=./pb_migrations --hooksDir=./pb_hooks --hooksWatch=false",
		"migrations:snapshot": "mkdir -p ./pb_snapshots && echo 'y' | .\\pocketbase migrate collections --dir=./pb_data --migrationsDir=./pb_snapshots",
		"update": ".\\pocketbase update --backup=0"
	}
}
